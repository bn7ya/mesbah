# ── Misbah backend env (copy to backend/.env) ────────────────────────────────
# All keys are optional; sensible defaults live in app/core/config.py.

# HuggingFace token (needed only for gated/private models)
MISBAH_HF_TOKEN=

# Default base model offered when creating a project
MISBAH_DEFAULT_BASE_MODEL=Qwen/Qwen3-14B

# Server
MISBAH_HOST=127.0.0.1
MISBAH_PORT=8077

# Hardware budget (RTX 5080 = 16 GB)
MISBAH_GPU_VRAM_GB=16
MISBAH_MAX_TRAIN_SEQ_LEN=4096

# Faster HF downloads (requires hf_transfer)
HF_HUB_ENABLE_HF_TRANSFER=1
